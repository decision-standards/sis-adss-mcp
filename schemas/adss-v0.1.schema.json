{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://decision-standards.org/adss/v0.1/schema.json",
    "title": "Agentic Decision System Specification (ADSS) v0.1.0",
    "description": "Canonical specification for designing coherent multi-agent systems, including flows, stages, agents, decision points, transitions, and feedback loops.",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "system_id",
      "schema_version",
      "created_at",
      "name",
      "objective",
      "flows",
      "agents"
    ],
    "properties": {
      "system_id": {
        "type": "string",
        "format": "uuid",
        "description": "Globally unique identifier for the ADSS system definition."
      },
      "schema_version": {
        "type": "string",
        "pattern": "^0\\.1\\.0$",
        "description": "ADSS schema version."
      },
      "created_at": {
        "type": "string",
        "format": "date-time",
        "description": "Timestamp when the ADSS system definition was created."
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Human-readable name of the system."
      },
      "description": {
        "type": "string",
        "description": "Optional description of the system."
      },
      "objective": {
        "$ref": "#/$defs/objective"
      },
      "agents": {
        "type": "array",
        "minItems": 1,
        "description": "Agents participating in the system.",
        "items": {
          "$ref": "#/$defs/agent"
        }
      },
      "flows": {
        "type": "array",
        "minItems": 1,
        "description": "Flows that define the system structure.",
        "items": {
          "$ref": "#/$defs/flow"
        }
      },
      "global_constraints": {
        "type": "array",
        "description": "Optional system-wide structural constraints.",
        "items": {
          "$ref": "#/$defs/global_constraint"
        },
        "default": []
      },
      "extensions": {
        "type": "object",
        "description": "Optional namespaced extension container.",
        "propertyNames": {
          "type": "string",
          "minLength": 1
        },
        "additionalProperties": true,
        "default": {}
      }
    },
    "$defs": {
      "objective": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "success_metric": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "time_horizon": {
            "type": "string"
          }
        }
      },
      "agent": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agent_id", "name", "role"],
        "properties": {
          "agent_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the agent."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable agent name."
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "description": "Functional role within the system."
          },
          "description": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "owns_stages": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "Optional list of stage_ids primarily owned by this agent."
          }
        }
      },
      "flow": {
        "type": "object",
        "additionalProperties": false,
        "required": ["flow_id", "name", "nodes", "transitions", "entry_node_id"],
        "properties": {
          "flow_id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "entry_node_id": {
            "type": "string",
            "description": "Node where the flow begins."
          },
          "nodes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/node"
            }
          },
          "transitions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/transition"
            }
          },
          "feedback_loops": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/feedback_loop"
            },
            "default": []
          }
        }
      },
      "node": {
        "oneOf": [
          { "$ref": "#/$defs/stage_node" },
          { "$ref": "#/$defs/decision_node" },
          { "$ref": "#/$defs/event_node" }
        ]
      },
      "base_node": {
        "type": "object",
        "required": ["node_id", "node_type", "name"],
        "properties": {
          "node_id": {
            "type": "string",
            "description": "Unique identifier for the node within the flow."
          },
          "node_type": {
            "type": "string",
            "description": "Discriminator for node type."
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          }
        }
      },
      "stage_node": {
        "allOf": [
          { "$ref": "#/$defs/base_node" },
          {
            "type": "object",
            "required": ["stage_id", "owner_agent_id"],
            "properties": {
              "node_type": {
                "const": "stage"
              },
              "stage_id": {
                "type": "string",
                "description": "Identifier for the logical stage."
              },
              "owner_agent_id": {
                "type": "string",
                "description": "Agent responsible for this stage."
              },
              "stage_kind": {
                "type": "string",
                "enum": [
                  "intake",
                  "evaluation",
                  "action",
                  "monitoring",
                  "analysis",
                  "custom"
                ],
                "default": "custom"
              },
              "inputs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "outputs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              }
            }
          }
        ]
      },
      "decision_node": {
        "allOf": [
          { "$ref": "#/$defs/base_node" },
          {
            "type": "object",
            "required": ["sis_ref"],
            "properties": {
              "node_type": {
                "const": "decision"
              },
              "decision_kind": {
                "type": "string",
                "enum": [
                  "eligibility",
                  "selection",
                  "authorization",
                  "routing",
                  "escalation",
                  "custom"
                ],
                "default": "custom"
              },
              "sis_ref": {
                "$ref": "#/$defs/sis_reference"
              },
              "possible_outcomes": {
                "type": "array",
                "description": "Expected SIS outcomes used for downstream branching.",
                "items": {
                  "type": "string",
                  "enum": ["allow", "deny", "escalate", "modify"]
                },
                "default": ["allow", "deny", "escalate"]
              }
            }
          }
        ]
      },
      "event_node": {
        "allOf": [
          { "$ref": "#/$defs/base_node" },
          {
            "type": "object",
            "required": ["event_kind"],
            "properties": {
              "node_type": {
                "const": "event"
              },
              "event_kind": {
                "type": "string",
                "enum": [
                  "trigger",
                  "wait",
                  "external_signal",
                  "completion",
                  "custom"
                ]
              }
            }
          }
        ]
      },
      "sis_reference": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intent_type"],
        "properties": {
          "intent_type": {
            "type": "string",
            "minLength": 1,
            "description": "SIS intent type expected at this decision point."
          },
          "schema_version": {
            "type": "string",
            "description": "Expected SIS schema version."
          },
          "profile": {
            "type": "string",
            "description": "Optional domain-specific SIS profile."
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "transition": {
        "type": "object",
        "additionalProperties": false,
        "required": ["transition_id", "from_node_id", "to_node_id"],
        "properties": {
          "transition_id": {
            "type": "string"
          },
          "from_node_id": {
            "type": "string"
          },
          "to_node_id": {
            "type": "string"
          },
          "condition_type": {
            "type": "string",
            "enum": [
              "always",
              "decision_outcome",
              "state_condition",
              "external_signal",
              "time_condition",
              "custom"
            ],
            "default": "always"
          },
          "condition": {
            "type": "string",
            "description": "Human-readable or machine-readable transition condition."
          },
          "label": {
            "type": "string",
            "description": "Optional display label for the transition."
          }
        }
      },
      "feedback_loop": {
        "type": "object",
        "additionalProperties": false,
        "required": ["loop_id", "from_node_id", "to_node_id", "reason"],
        "properties": {
          "loop_id": {
            "type": "string"
          },
          "from_node_id": {
            "type": "string"
          },
          "to_node_id": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "description": "Why the system re-enters an earlier part of the flow."
          },
          "trigger": {
            "type": "string",
            "description": "Optional trigger for the loop."
          }
        }
      },
      "global_constraint": {
        "type": "object",
        "additionalProperties": false,
        "required": ["constraint_id", "type", "rule"],
        "properties": {
          "constraint_id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "sequencing",
              "segregation_of_duties",
              "approval_requirement",
              "data_dependency",
              "custom"
            ]
          },
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["warn", "block"],
            "default": "warn"
          }
        }
      }
    }
  }